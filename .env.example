# ============================================================================
# DUYS Boost — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control — it contains secrets!
# ============================================================================

# ── Flask Security ───────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=<generate-a-strong-random-hex-string>

# ── PostgreSQL (REQUIRED) ────────────────────────────────────────────────────
# Render:   set automatically when you attach a Postgres instance (DATABASE_URL)
# Railway:  set automatically (DATABASE_URL)
# Heroku:   set automatically (DATABASE_URL)
# Local:    create a database then set this:
#           createdb duys_boost
DATABASE_URL=postgresql://user:password@localhost:5432/duys_boost

# ── Cookies ──────────────────────────────────────────────────────────────────
# Set to 1 in production (HTTPS only)
COOKIE_SECURE=0

# ── Crypto Payment Wallets ───────────────────────────────────────────────────
# USDT deposit addresses — users send funds here
CRYPTO_WALLET_APTOS=your_aptos_usdt_wallet_address_here
CRYPTO_WALLET_AVALANCHE=your_avalanche_usdt_wallet_address_here
CRYPTO_WALLET_BSC=your_bsc_usdt_wallet_address_here

# ── Crypto Withdrawal Keys (HOT WALLET — KEEP SECRET) ────────────────────────
# Private keys for automated USDT payouts — must control the wallets above
WITHDRAWAL_KEY_APTOS=your_aptos_private_key_here
WITHDRAWAL_KEY_AVALANCHE=your_avalanche_private_key_here
WITHDRAWAL_KEY_BSC=your_bsc_private_key_here

# ── Google OAuth (optional) ──────────────────────────────────────────────────
# https://console.cloud.google.com — OAuth 2.0 credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here


# ── Cloudflare R2 Object Storage ─────────────────────────────────────────────
# Zero egress fees — serving media to users costs nothing.
#
# Setup (takes ~5 minutes):
#   1. Go to Cloudflare Dashboard → R2 → Create bucket (e.g. duys-boost-media)
#   2. On the bucket → Settings → Public Access → Enable
#      Copy the r2.dev URL shown (e.g. https://pub-xxxx.r2.dev)
#      Or connect a custom domain for a cleaner URL.
#   3. Go to R2 Overview → Manage R2 API Tokens → Create Token
#      Permissions: Object Read & Write  |  Bucket: your bucket
#      Copy the Access Key ID and Secret Access Key shown ONCE.
#   4. Copy your Account ID from the R2 overview page URL or sidebar.

# R2 API credentials — used for BOTH buckets
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# Bucket 1 — Public media (images, videos, avatars, stories)
R2_BUCKET_NAME=duys-boost-media

# Bucket 2 — Private per-user SQLite databases (KEEP PRIVATE — no public access)
# Create a separate R2 bucket with public access DISABLED for this
R2_DB_BUCKET_NAME=duys-boost-databases

# Your Cloudflare Account ID (top-right of dashboard or in URL)
R2_ACCOUNT_ID=your_cloudflare_account_id

# Public URL for serving files (from step 2 — r2.dev URL or custom domain)
# e.g. https://pub-abc123def456.r2.dev
# or   https://media.yourdomain.com
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Max upload size in MB (default: 25)
R2_MAX_FILE_MB=25

# ── Security ─────────────────────────────────────────────────────────────────
# Optional: Redis for distributed rate limiting across multiple workers.
# Without this, rate limits use in-memory storage (resets on restart,
# not shared between workers). Fine for single-worker dev/staging.
# Example: redis://localhost:6379/0  or  rediss://user:pass@host:6380/0
REDIS_URL=

# ── Admin Account (set before first deploy — creates the admin user) ─────────
# If not set, a random secure password is generated and logged on first boot.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_this_to_a_strong_password

# ── Application Settings ─────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=0
