# ============================================================================
# DUYS Boost — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to source control — it contains secrets!
#
# For production, ensure COOKIE_SECURE=1 and use LIVE Paystack keys.
# ============================================================================

# Flask Security (generate with: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=<generate-a-strong-random-hex-string>

# Cookies (set COOKIE_SECURE=1 in production with HTTPS)
COOKIE_SECURE=0

# Paystack Integration (https://dashboard.paystack.com)
# Use pk_test_* and sk_test_* for testing
# Use pk_live_* and sk_live_* for production
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here

# Google OAuth (https://console.cloud.google.com)
# Create OAuth 2.0 credentials (Authorized JavaScript origins + Redirect URIs)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Application Settings
PORT=5000
FLASK_DEBUG=0
