# ============================================================================
# DUYS Boost — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to source control — it contains secrets!
# ============================================================================

# Flask Security (generate with: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=<generate-a-strong-random-hex-string>

# Cookies (set COOKIE_SECURE=1 in production with HTTPS)
COOKIE_SECURE=0

# ── Crypto Payment Wallets ──────────────────────────────────────────────────
# USDT deposit addresses for each supported network.
# Users will send USDT to these addresses; admin confirms after verifying TX.
CRYPTO_WALLET_APTOS=your_aptos_usdt_wallet_address_here
CRYPTO_WALLET_AVALANCHE=your_avalanche_usdt_wallet_address_here
CRYPTO_WALLET_BSC=your_bsc_usdt_wallet_address_here

# ── Google OAuth (optional) ─────────────────────────────────────────────────
# https://console.cloud.google.com — OAuth 2.0 credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── Application Settings ────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=0
